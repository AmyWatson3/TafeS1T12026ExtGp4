<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!-- GridStyle -->
	<Style x:Key="GridStyle" TargetType="Grid">
		<Setter Property="Margin" Value="10" />
		<Setter Property="RowSpacing" Value="10" />
		<Setter Property="ColumnSpacing" Value="10" />
	</Style>
	
	<!-- FlyoutStyle -->
	<Style x:Key="FlyoutStyle" TargetType="FlyoutPresenter">
		<Setter Property="Width" Value="Auto" />
		<Setter Property="Height" Value="Auto" />
	</Style>

	<!-- ButtonStyle -->
	<Style x:Key="ButtonStyle" TargetType="Button">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontSize" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Stretch" />
		<Setter Property="IsTabStop" Value="False" />
	</Style>

	<!-- ButtonBlueStyle -->
	<Style x:Key="ButtonBlueStyle" TargetType="Button"
		BasedOn="{StaticResource ButtonStyle}">
		<Setter Property="Background" Value="LightYellow" />
	</Style>

	<!-- Menu button style -->
	<Style x:Key="MenuButtonStyle" TargetType="Button"
		BasedOn="{StaticResource ButtonStyle}">
		<Setter Property="Background" Value="#FFAAADB0" />
		<Setter Property="BorderBrush" Value="Black" />
		<Setter Property="IsTabStop" Value="True" />
		<Setter Property="Margin" Value="10,0,10,0" />
	</Style>
	
	<!-- Page button style -->
	<Style x:Key="PageButtonStyle" TargetType="Button"
		BasedOn="{StaticResource MenuButtonStyle}">
		<Setter Property="FontSize" Value="32" />
		<Setter Property="FontStyle" Value="Normal" />
		<Setter Property="Margin" Value="15,0,15,0"/>
		<Setter Property="MinHeight" Value="100" /> 
	</Style>

	<!-- HeadingTextBlockStyle -->
	<Style x:Key="HeadingTextBlockStyle" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontWeight" Value="Bold" />
		<Setter Property="FontSize" Value="36" />
	</Style>
	
	<!-- BigTextBlockStyle -->
	<Style x:Key="BigTextBlockStyle" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontSize" Value="32" />
	</Style>
	
	<!-- SmallTextBlockStyle -->
	<Style x:Key="SmallTextBlockStyle" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="Height" Value="37" />
	</Style>
	
	<!-- FlyoutTextBlockStyle -->
	<Style x:Key="FlyoutTextBlockStyle" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontSize" Value="14" />
	</Style>
	
	<!-- ErrorFlyoutTextBlockStyle -->
	<Style x:Key="ErrorFlyoutTextBlockStyle" TargetType="TextBlock"
		BasedOn="{StaticResource FlyoutTextBlockStyle}" >
		<Setter Property="Foreground" Value="Red" />
	</Style>

	<!-- LabelBlockStyle -->
	<Style x:Key="LabelBlockStyle" TargetType="TextBlock"
		BasedOn="{StaticResource BigTextBlockStyle}" >
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>

	<!-- TextBoxStyle -->
	<Style x:Key="TextBoxStyle" TargetType="TextBox">
		<Setter Property="FontFamily" Value="Arial" />
		<Setter Property="FontSize" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Stretch" />
	</Style>

	<Style x:Key="NumericTextBoxStyle" TargetType="TextBox"
		   BasedOn="{StaticResource TextBoxStyle}" >
		<Setter Property="TextAlignment" Value="Right" />
	</Style>

	<!-- ReadOnlyTextBoxStyle -->
	<Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox"
		   BasedOn="{StaticResource TextBoxStyle}" >
		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="IsReadOnly" Value="True" />
		<Setter Property="IsEnabled" Value="False" />
		<Setter Property="Background" Value="#FFAAADB0" />
	</Style>
	
	<Style x:Key="ReadOnlyNumericTextBoxStyle" TargetType="TextBox"
		   BasedOn="{StaticResource ReadOnlyTextBoxStyle}" >
		<Setter Property="TextAlignment" Value="Right" />
	</Style>

</ResourceDictionary>