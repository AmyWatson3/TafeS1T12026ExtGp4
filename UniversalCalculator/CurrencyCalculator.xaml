<Page
    x:Class="Calculator.CurrencyCalculator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<TextBlock HorizontalAlignment="Center" Text="Currency Conversion Calculator" FontSize="48" FontWeight="Bold" />
		<Grid Margin="20,100,20,20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Top Row -->
			<StackPanel>
				<TextBlock Text="Amount $" FontSize="36" Grid.Column="0" />
				<TextBox Text="100" Margin="0,10,25,0" x:Name="amountTextBox"></TextBox>
			</StackPanel>

			<StackPanel Grid.Column="1">
				<TextBlock Text="From" FontSize="36"  Grid.Column="1" />
				<ComboBox Grid.Column="1" Margin="0,10,25,0" Width="350" x:Name="fromComboBox" SelectedIndex="0" ItemsSource="{x:Bind currencies}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>

								<Image Grid.Column="1"
									   Source="{Binding Image}"
									   Width="16"
									   Height="16"
									   Margin="8,0,0,0"/>
							</Grid>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
			</StackPanel>

			<StackPanel Grid.Column="2">
				<TextBlock Text="To" FontSize="36"  Grid.Column="2" />
				<ComboBox Grid.Column="1" Margin="0,10,25,0" Width="350" x:Name="toComboBox" SelectedIndex="1" ItemsSource="{x:Bind currencies}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>

								<Image Grid.Column="1"
								   Source="{Binding Image}"
								   Width="16"
								   Height="16"
								   Margin="8,0,0,0"/>
							</Grid>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
			</StackPanel>

			<!-- Middle Row -->
			<StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" VerticalAlignment="Center">
				<TextBlock x:Name="amountTextBlock" FontSize="28" Margin="10" />
				<TextBlock x:Name="resultTextBlock" FontSize="28" Margin="10" />
				<TextBlock x:Name="fromConversionTextBlock" FontSize="28" Margin="10" />
				<TextBlock x:Name="toConversionTextBlock" FontSize="28" Margin="10" />
			</StackPanel>

			<!-- Bottom Row -->
			<StackPanel Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center" Margin="10">
				<Button Margin="10" Height="50" Width="300" FontSize="24" Click="currencyButton_Click">Calculate Currency</Button>
				<Button Margin="10" Height="50" Width="300" FontSize="24" Click="exitButton_Click">Exit</Button>
			</StackPanel>
		</Grid>
	</Grid>
</Page>
